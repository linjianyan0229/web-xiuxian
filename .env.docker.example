# Copy this file to .env before running docker compose.

# Public URL used by the browser. For local deployment, keep this value.
FRONTEND_ORIGIN=http://localhost:8080
WEB_PORT=8080
TZ=Asia/Shanghai

# MySQL container settings. The backend uses root because the current startup
# code creates the database if it does not exist.
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password
DB_NAME=web_xiuxian

# Production startup requires a strong non-default JWT secret.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Seeded only when users has no admin row. Do not use the development default.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@xiuxian.local

# SMTP settings for email verification and password reset.
# Leave SMTP_HOST empty only for local testing. In production, sending codes
# returns 503 until a real SMTP provider is configured.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
