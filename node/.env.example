# 运行环境：development / production
# 设为 production 时，启动前会强制校验 JWT_SECRET / DB_PASSWORD / ADMIN_PASSWORD 非默认值
NODE_ENV=development

# 服务端口
PORT=3000

# 允许跨域访问的前端来源（生产必填；多个用英文逗号分隔，如 https://a.com,https://b.com）
# 留空时：开发环境放开所有来源，生产环境将拒绝浏览器跨域请求
FRONTEND_ORIGIN=

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=web_xiuxian

# JWT 鉴权配置（生产环境必须改为强随机值，建议 32 位以上）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# 默认管理员账号（仅首次启动、users 表无 role=1 记录时生成；账号即道号）
# 生产环境必须设置 ADMIN_PASSWORD，否则不会自动播种管理员（避免默认弱口令）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@xiuxian.local
