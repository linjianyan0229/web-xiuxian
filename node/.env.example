# 运行环境：development / production
# 设为 production 时，启动前会强制校验 JWT_SECRET / DB_PASSWORD / ADMIN_PASSWORD 非默认值
NODE_ENV=development

# 服务端口
PORT=3000

# 允许跨域访问的前端来源（生产必填；多个用英文逗号分隔，如 https://a.com,https://b.com）
# 留空时：开发环境放开所有来源，生产环境将拒绝浏览器跨域请求
FRONTEND_ORIGIN=

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=web_xiuxian

# JWT 鉴权配置（生产环境必须改为强随机值，建议 32 位以上）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# 默认管理员账号（仅首次启动、users 表无 role=1 记录时生成；账号即道号）
# 生产环境必须设置 ADMIN_PASSWORD，否则不会自动播种管理员（避免默认弱口令）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@xiuxian.local

# SMTP 发信配置（邮箱验证码：注册 / 重置密码）
# SMTP_HOST 留空视为未配置——开发环境验证码会打印到后端控制台（方便本地联调），
# 生产环境发送验证码接口将返回 503。常见服务商示例：
#   QQ 邮箱   smtp.qq.com   465（SMTP_PASS 用授权码而非登录密码）
#   163 邮箱  smtp.163.com  465（同上，用授权码）
#   Gmail    smtp.gmail.com 465（用应用专用密码）
SMTP_HOST=
SMTP_PORT=465
# 465 为隐式 TLS 保持 1；587/25 STARTTLS 设为 0
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
# 发件人显示（留空时用 SMTP_USER），如：文字修仙 <no-reply@example.com>
MAIL_FROM=
